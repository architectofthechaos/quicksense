{
  "realm": "quicksense",
  "enabled": true,
  "displayName": "QuickSense",
  "loginTheme": "quicksense",
  "displayNameHtml": "<div style=\"font-family:Inter,system-ui,sans-serif;font-size:26px;font-weight:700;letter-spacing:-0.02em;color:#15131F\">Quick<span style=\"color:#5A48E0\">Sense</span></div>",
  "sslRequired": "NONE",
  "roles": {
    "realm": [
      {
        "name": "polaris_admin",
        "description": "Future Polaris principal role mapping target."
      }
    ]
  },
  "clients": [
    {
      "clientId": "quicksense-api",
      "name": "QuickSense API",
      "enabled": true,
      "protocol": "openid-connect",
      "publicClient": false,
      "secret": "${KEYCLOAK_CLIENT_SECRET}",
      "standardFlowEnabled": true,
      "serviceAccountsEnabled": true,
      "directAccessGrantsEnabled": true,
      "authorizationServicesEnabled": false,
      "redirectUris": [
        "http://localhost:3000/*"
      ],
      "webOrigins": [
        "+"
      ]
    },
    {
      "clientId": "quicksense-ui",
      "name": "QuickSense Web UI",
      "enabled": true,
      "protocol": "openid-connect",
      "publicClient": false,
      "secret": "${KEYCLOAK_UI_CLIENT_SECRET}",
      "standardFlowEnabled": true,
      "directAccessGrantsEnabled": true,
      "serviceAccountsEnabled": false,
      "authorizationServicesEnabled": false,
      "redirectUris": [
        "http://localhost:3000/api/auth/callback/keycloak",
        "http://localhost:3000/*"
      ],
      "webOrigins": [
        "http://localhost:3000"
      ],
      "attributes": {
        "post.logout.redirect.uris": "http://localhost:3000##http://localhost:3000/*"
      }
    }
  ],
  "users": [
    {
      "username": "service-account-quicksense-api",
      "enabled": true,
      "serviceAccountClientId": "quicksense-api",
      "realmRoles": [
        "polaris_admin"
      ]
    },
    {
      "username": "qsuser",
      "enabled": true,
      "emailVerified": true,
      "email": "qsuser@quicksense.local",
      "firstName": "QuickSense",
      "lastName": "User",
      "requiredActions": [],
      "credentials": [
        {
          "type": "password",
          "value": "${KEYCLOAK_TEST_PASSWORD}",
          "temporary": false
        }
      ],
      "realmRoles": [
        "polaris_admin"
      ]
    }
  ]
}
