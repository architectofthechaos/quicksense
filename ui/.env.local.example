# Auth.js session encryption secret — generate with: openssl rand -base64 32
AUTH_SECRET=replace-me

# Keycloak OIDC (confidential client quicksense-ui)
AUTH_KEYCLOAK_ID=quicksense-ui
AUTH_KEYCLOAK_SECRET=qs-ui-secret
AUTH_KEYCLOAK_ISSUER=http://localhost:8082/realms/quicksense

# Auth.js base URL
NEXTAUTH_URL=http://localhost:3000
AUTH_URL=http://localhost:3000
# Allow http callback host in dev
AUTH_TRUST_HOST=true

# Go control-plane API (kind: kubectl port-forward svc/quicksense-api 8090:8090)
QUICKSENSE_API_BASE_URL=http://localhost:8090
